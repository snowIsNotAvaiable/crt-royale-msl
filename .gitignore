#   - outputs/   is produced by tests/validate.sh
#   - reference/ is produced by tests/capture_reference.sh (librashader-cli)
#   - diff/      is produced by tests/compare_all.sh
tests/inputs/*.png
tests/outputs/
tests/reference/
tests/diff/
